# ──────────────────────────────────────────────────────────
# LadderFlow backend — environment variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ──────────────────────────────────────────────────────────

# ── AI Providers ─────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
PERPLEXITY_API_KEY=

# ── STT ──────────────────────────────────────────────────
DEEPGRAM_API_KEY=
VITE_DEEPGRAM_API_KEY=

# ── TTS providers (only those you use) ───────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
CARTESIA_API_KEY=
INWORLD_API_KEY=

# ── Databases ────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:pass@host/db?ssl=require
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USERNAME=
NEO4J_PASSWORD=

# ── LiveKit Cloud ────────────────────────────────────────
LIVEKIT_URL=wss://your-instance.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ── Upstash Redis (for rate limiter) ─────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── App config ───────────────────────────────────────────
INTERNAL_SECRET=
SECRET_KEY=
FRONTEND_URL=http://localhost:3000
BACKEND_INTERNAL_URL=http://127.0.0.1:8000
